{
  "manifest_version": 3,
  "name": "42 Coalition Map",
  "description": "Displays coalition colors for each user on the 42 intra cluster map",
  "version": "1.1.0",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://*.intra.42.fr/*",
    "https://api.intra.42.fr/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "42 Coalition Map"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.intra.42.fr/clusters*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://projects.intra.42.fr/projects/*",
        "https://profile.intra.42.fr/projects/*"
      ],
      "js": ["leaderboard.js"],
      "css": ["leaderboard.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
